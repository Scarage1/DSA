#include <bits/stdc++.h>
#include <iostream>
using namespace std;

class Solution {
public:
    bool rotateString(string s, string goal) {

        if (s.length() != goal.length()) {
            return false;
        }

        string temp = s + s;

        return temp.find(goal) != string::npos;
    }
};

int main() {

    Solution obj;

    string s = "abcde";
    string goal = "cdeab";

    if (obj.rotateString(s, goal))
        cout << "True" << endl;
    else
        cout << "False" << endl;

    return 0;
}